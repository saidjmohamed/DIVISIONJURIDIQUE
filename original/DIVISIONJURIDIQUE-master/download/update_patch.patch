+/* ========================================
+   PART 9 — Toast إشعار
+   ======================================== */
+.toast {
+  position: fixed;
+  bottom: calc(90px + env(safe-area-inset-bottom));
+  left: 50%;
+  transform: translateX(-50%) translateY(20px);
+  color: white;
+  padding: 12px 20px;
+  border-radius: var(--radius-xl);
+  font-size: 14px;
+  font-weight: 600;
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  box-shadow: var(--shadow-lg);
+  z-index: 9999;
+  opacity: 0;
+  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
+  white-space: nowrap;
+  direction: rtl;
+}
+
+.toast.toast-visible {
+  opacity: 1;
+  transform: translateX(-50%) translateY(0);
+}
+
+.toast.toast-success { background: #22c55e; }
+.toast.toast-info { background: #3b82f6; }
+.toast.toast-warning { background: #f59e0b; }
+.toast.toast-error { background: #ef4444; }
+
+/* ========================================
+   PART 3 — شريط التنقل السفلي المُحسَّن
+   ======================================== */
+.bottom-nav-enhanced {
+  position: fixed;
+  bottom: 0;
+  left: 50%;
+  transform: translateX(-50%);
+  width: 100%;
+  max-width: 480px;
+  background: white;
+  border-top: none;
+  box-shadow: var(--shadow-nav);
+  display: flex;
+  padding: 8px 4px calc(8px + env(safe-area-inset-bottom));
+  gap: 2px;
+  z-index: 200;
+  border-radius: 24px 24px 0 0;
+}
+
+@media (prefers-color-scheme: dark) {
+  .bottom-nav-enhanced {
+    background: #1e293b;
+    border-top: 1px solid #334155;
+  }
+}
+
+.nav-item-enhanced {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  gap: 4px;
+  padding: 6px 4px;
+  cursor: pointer;
+  border-radius: var(--radius-md);
+  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
+  position: relative;
+  background: transparent;
+  border: none;
+  -webkit-tap-highlight-color: transparent;
+}
+
+/* التبويب النشط */
+.nav-item-enhanced.active {
+  background: linear-gradient(135deg, var(--tab-color, var(--navy)) 0%,
+              color-mix(in srgb, var(--tab-color, var(--navy)) 80%, black) 100%);
+  transform: translateY(-4px);
+  box-shadow: 0 6px 20px color-mix(in srgb, var(--tab-color, var(--navy)) 40%, transparent);
+}
+
+.nav-item-enhanced.active .nav-icon,
+.nav-item-enhanced.active .nav-label {
+  color: white;
+}
+
+.nav-icon {
+  font-size: 20px;
+  transition: transform 0.25s;
+  color: var(--text-muted);
+}
+
+.nav-label {
+  font-size: 10px;
